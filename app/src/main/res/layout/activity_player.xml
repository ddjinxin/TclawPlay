<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- 沉浸封面背景（封面原图铺满） -->
    <ImageView
        android:id="@+id/blur_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0"
        android:visibility="gone" />

    <!-- 沉浸模式渐变遮罩 -->
    <com.jingxin.jingxinmusic.view.ImmersiveOverlayView
        android:id="@+id/immersive_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- 沉浸模式夜间半透明黑色遮罩（压暗封面，保留色调） -->
    <View
        android:id="@+id/immersive_dark_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone" />

    <!-- 白色遮罩层（白天模式非沉浸时使用，渐变由代码设置） -->
    <View
        android:id="@+id/white_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- 半透明遮罩（夜间模式非沉浸时使用） -->
    <View
        android:id="@+id/overlay_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA000000" />

    <!-- 主内容：左侧信息区 -->
    <LinearLayout
        android:id="@+id/info_panel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- 封面占位（竖屏时留出封面空间） -->
        <View
            android:id="@+id/cover_placeholder"
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:layout_weight="0"
            android:visibility="gone" />

        <!-- 歌名 -->
        <TextView
            android:id="@+id/song_name_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="16dp"
            android:text="未知歌曲"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:gravity="center_horizontal" />

        <!-- 歌手 -->
        <TextView
            android:id="@+id/artist_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="8dp"
            android:text="未知歌手"
            android:textColor="#AAAAAA"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:gravity="center_horizontal" />

        <!-- 歌词 -->
        <com.jingxin.jingxinmusic.view.LyricView
            android:id="@+id/lyric_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp" />

        <!-- 频谱 -->
        <com.jingxin.jingxinmusic.view.SpectrumView
            android:id="@+id/spectrum_view"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginBottom="16dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp" />

        <!-- 进度条 -->
        <LinearLayout
            android:id="@+id/progress_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/current_time_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="00:00"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/progress_seek_bar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="0"
                android:minHeight="4dp"
                android:maxHeight="4dp"
                android:progressDrawable="@drawable/seekbar_progress"
                android:thumb="@drawable/seekbar_thumb" />

            <TextView
                android:id="@+id/total_time_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="00:00"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- 底部按钮 -->
        <LinearLayout
            android:id="@+id/control_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/previous_button"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:padding="6dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/ripple_control_button"
                android:src="@drawable/ic_previous" />

            <ImageView
                android:id="@+id/play_pause_button"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:padding="6dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/ripple_control_button"
                android:src="@drawable/ic_play" />

            <ImageView
                android:id="@+id/next_button"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:padding="6dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/ripple_control_button"
                android:src="@drawable/ic_next" />

            <ImageView
                android:id="@+id/play_order_button"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:padding="6dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/ripple_control_button"
                android:src="@drawable/ic_play_order_sequential" />

            <ImageView
                android:id="@+id/history_button"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/ripple_control_button"
                android:src="@drawable/ic_history" />

            <ImageView
                android:id="@+id/mode_button"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/ripple_control_button"
                android:src="@drawable/ic_favorite" />

        </LinearLayout>

    </LinearLayout>

    <!-- 旋转封面（独立于 info_panel，通过 LayoutParams 定位） -->
    <com.jingxin.jingxinmusic.view.RotatingCoverView
        android:id="@+id/cover_view"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="center_horizontal|top"
        android:layout_marginTop="32dp" />

    <!-- 顶部按钮栏：返回(左) + 弹性空间 + 右3按钮组(占35%宽度) -->
    <LinearLayout
        android:id="@+id/top_buttons_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/back_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:padding="6dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <!-- 中间弹性空间 -->
        <View
            android:id="@+id/top_spacer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 右侧三按钮容器，宽度由代码动态设置为页面35% -->
        <LinearLayout
            android:id="@+id/right_buttons_group"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/spectrum_button"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:src="@drawable/ic_spectrum"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <ImageView
                android:id="@+id/outfit_button"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:src="@drawable/ic_outfit"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <ImageView
                android:id="@+id/theme_button"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:src="@drawable/ic_theme"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>

    </LinearLayout>

    <!-- 唱臂（最顶层，唱片机模式专用，默认隐藏，位置和尺寸由代码动态计算） -->
    <com.jingxin.jingxinmusic.view.TonearmView
        android:id="@+id/tonearm_view"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:visibility="gone" />

</FrameLayout>
