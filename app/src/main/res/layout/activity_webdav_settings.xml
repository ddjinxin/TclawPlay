<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/content_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 顶部栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="6dp"
                android:src="@drawable/ic_back"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="WebDAV 设置"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <View
            android:id="@+id/divider_top"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp" />

        <!-- 服务器地址 -->
        <TextView
            android:id="@+id/tv_label_server"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="服务器地址"
            android:textSize="14sp"
            android:layout_marginTop="16dp" />

        <EditText
            android:id="@+id/et_server_url"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="https://dav.example.com/"
            android:textSize="16sp"
            android:background="@android:color/transparent"
            android:inputType="textUri"
            android:singleLine="true"
            android:paddingVertical="12dp" />

        <View
            android:id="@+id/divider_server"
            android:layout_width="match_parent"
            android:layout_height="1dp" />

        <!-- 用户名 -->
        <TextView
            android:id="@+id/tv_label_username"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="用户名"
            android:textSize="14sp"
            android:layout_marginTop="16dp" />

        <EditText
            android:id="@+id/et_username"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="输入用户名"
            android:textSize="16sp"
            android:background="@android:color/transparent"
            android:inputType="text"
            android:singleLine="true"
            android:paddingVertical="12dp" />

        <View
            android:id="@+id/divider_username"
            android:layout_width="match_parent"
            android:layout_height="1dp" />

        <!-- 密码 -->
        <TextView
            android:id="@+id/tv_label_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="密码"
            android:textSize="14sp"
            android:layout_marginTop="16dp" />

        <EditText
            android:id="@+id/et_password"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="输入密码"
            android:textSize="16sp"
            android:background="@android:color/transparent"
            android:inputType="textPassword"
            android:singleLine="true"
            android:paddingVertical="12dp" />

        <View
            android:id="@+id/divider_password"
            android:layout_width="match_parent"
            android:layout_height="1dp" />

        <!-- 音乐目录 -->
        <TextView
            android:id="@+id/tv_label_path"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="音乐目录"
            android:textSize="14sp"
            android:layout_marginTop="16dp" />

        <EditText
            android:id="@+id/et_music_path"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="/music/"
            android:textSize="16sp"
            android:background="@android:color/transparent"
            android:inputType="text"
            android:singleLine="true"
            android:paddingVertical="12dp" />

        <View
            android:id="@+id/divider_path"
            android:layout_width="match_parent"
            android:layout_height="1dp" />

        <!-- 缓存设置 -->
        <TextView
            android:id="@+id/tv_label_cache"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="缓存设置"
            android:textSize="14sp"
            android:layout_marginTop="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tv_cache_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="缓存大小上限"
                android:textSize="16sp" />

            <Spinner
                android:id="@+id/spinner_cache_size"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:spinnerMode="dropdown" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_cache_used"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="当前已用: 0MB"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <Button
            android:id="@+id/btn_clear_cache"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="清除缓存"
            android:textSize="16sp"
            android:background="@android:color/transparent"
            android:layout_marginTop="4dp" />

        <View
            android:id="@+id/divider_cache"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp" />

        <!-- 操作按钮：横排 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btn_test_connection"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="测试"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:backgroundTint="#4CAF50"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="保存"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:backgroundTint="#2196F3"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btn_import"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="提取"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:backgroundTint="#FF9800"
                android:layout_marginStart="6dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
